{
  "name": "davidlowelarsson.com",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "astro check",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "media:sync": "node --experimental-strip-types scripts/media-sync.mjs",
    "media:check": "node --experimental-strip-types scripts/media-check.mjs",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run e2e"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.2",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.6",
    "markdown-it": "^14.3.0",
    "mermaid": "^11.16.0",
    "sanitize-html": "^2.17.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.5.2",
    "@playwright/test": "^1.61.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^26.1.0",
    "@types/sanitize-html": "^2.16.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.107.0",
    "yaml": "^2.9.0"
  }
}
