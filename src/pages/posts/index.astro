---
import { getCollection } from 'astro:content';
import { SHOW_DRAFTS } from 'astro:env/server';
import PostList from '../../components/PostList.astro';
import Base from '../../layouts/Base.astro';
import { CATEGORIES, groupByYear, isVisible, sortByPubDateDesc } from '../../lib/posts';
import { collectionPageJsonLd } from '../../lib/seo';

const posts = sortByPubDateDesc(
  await getCollection('posts', ({ data }) => isVisible(data, SHOW_DRAFTS)),
);
const years = groupByYear(posts);

const site = Astro.site?.href ?? 'https://davidlowelarsson.com';
---

<Base
  title="Posts — David Lowe Larsson"
  jsonLd={collectionPageJsonLd('Posts', 'All writing by David Lowe Larsson.', posts, site)}
>
  <h1>Posts</h1>
  <nav class="filter-rail" aria-label="Filter by category">
    <span aria-current="true">all</span>
    {CATEGORIES.map((category) => <a href={`/category/${category}/`}>{category}</a>)}
  </nav>
  {
    years.length > 0 ? (
      years.map(({ year, posts: yearPosts }) => (
        <>
          <h2 class="year-heading">{year}</h2>
          <PostList posts={yearPosts} />
        </>
      ))
    ) : (
      <p>Nothing published yet — the first posts are still drafts.</p>
    )
  }
</Base>
