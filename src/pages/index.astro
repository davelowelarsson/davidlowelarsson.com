---
import { getCollection } from 'astro:content';
import { SHOW_DRAFTS } from 'astro:env/server';
import PostList from '../components/PostList.astro';
import Base from '../layouts/Base.astro';
import { BYLINES } from '../lib/bylines';
import { isVisible, sortByPubDateDesc } from '../lib/posts';
import { profilePageJsonLd } from '../lib/seo';

const recent = sortByPubDateDesc(
  await getCollection('posts', ({ data }) => isVisible(data, SHOW_DRAFTS)),
).slice(0, 3);

const site = Astro.site?.href ?? 'https://davidlowelarsson.com';
---

<Base title="David Lowe Larsson" jsonLd={profilePageJsonLd(site)}>
  <h1>David Lowe Larsson</h1>
  <p class="tagline" id="tagline">{BYLINES[0]}</p>
  {/*
    No-flash contract — do not move or "clean up" this script.
    Inline + parser-blocking (define:vars implies is:inline), placed RIGHT AFTER
    the element, so it runs before the browser paints the tagline: the random
    byline is chosen pre-paint, no flash. No JS → the server-rendered canonical
    byline (bylines[0]) simply stays.
    If this is ever bundled (bare <script>), moved away from the element, or the
    site adopts <ClientRouter/>, the flash returns / rotation breaks. The guard
    is e2e/byline-rotation.spec.ts; the reasoning is in docs/astro-field-guide.md.
  */}
  <script define:vars={{ bylines: BYLINES }}>
    const el = document.getElementById('tagline');
    if (el) el.textContent = bylines[Math.floor(Math.random() * bylines.length)];
  </script>
  <p>
    I write <a href="/category/essay/">essays</a> — sometimes about how things were fifteen years ago,
    sometimes about where I think they're going — <a href="/category/til/">quick notes</a> captured the
    day I learn something, and <a href="/category/experiment/">experiments</a> from the home lab and
    elsewhere. Now and then the old visual effects and 3D work shows up, or some new 3D printing,
    mostly because it's fun to remember and fun to build.
  </p>
  <p>
    I started in 3D art and visual effects — Maya, ZBrush, After Effects — modeling, texturing,
    animating, and writing shaders and exporters because the tools were never quite what I
    needed. Somewhere along the way, building the tools became the craft. These days I do
    technical leadership, DevSecOps, and platform engineering: Kubernetes, GitOps, automating
    things until they no longer need me… though there is always something more to automate 😅.
  </p>
  <p>
    Away from the keyboard I'm a husband and father of two girls. I sail when I can — and spend
    an unreasonable amount of time dreaming about a boat of my own — alongside an entirely
    unembarrassed amount of video games, series, and films. Probably more in a weekend than most
    people get through in a month.
  </p>
  <p>
    Looking for the résumé? That one lives
    on <a href="https://www.linkedin.com/in/davidlowelarsson/">LinkedIn ↗</a>. This is the rest.
  </p>

  {
    recent.length > 0 && (
      <section aria-labelledby="recent-heading">
        <h2 id="recent-heading" class="section-heading">
          Recent
        </h2>
        <PostList posts={recent} />
        <p class="all-posts">
          <a href="/posts/">All posts →</a>
        </p>
      </section>
    )
  }
</Base>
