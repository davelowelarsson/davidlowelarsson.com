---
import { getCollection } from 'astro:content';
import { SHOW_DRAFTS } from 'astro:env/server';
import PostList from '../components/PostList.astro';
import Base from '../layouts/Base.astro';
import { isVisible, sortByPubDateDesc } from '../lib/posts';
import { profilePageJsonLd } from '../lib/seo';

const recent = sortByPubDateDesc(
  await getCollection('posts', ({ data }) => isVisible(data, SHOW_DRAFTS)),
).slice(0, 3);

const site = Astro.site?.href ?? 'https://davidlowelarsson.com';
---

<Base title="David Lowe Larsson" jsonLd={profilePageJsonLd(site)}>
  <h1>David Lowe Larsson</h1>
  <p>
    I started in 3D art — Maya, ZBrush, writing shaders and exporters because the tools were never
    quite what I needed — and somewhere along the way, building the tools became the craft. These
    days I do technical leadership and platform engineering: Kubernetes, GitOps, automating things
    until they no longer need me. There is always something new to automate.
  </p>
  <p>
    This site is the notebook, not the résumé — that one lives on
    <a href="https://www.linkedin.com/in/davidlowelarsson/">LinkedIn</a>. Here I write notes, 
    <a href="/category/essay/">essays</a> maybe how things were fifteen years ago and where I think they
    seem to be going, <a href="/category/til/">quick notes</a> from the daily work,
    <a href="/category/experiment/">experiments</a> from the home lab — and, eventually, some of
    the old visual effects, 3D and art work, documented mostly because it's fun to remember.
  </p>

  <section aria-labelledby="recent-heading">
    <h2 id="recent-heading" class="section-heading">Recent</h2>
    <PostList posts={recent} />
    <p class="all-posts"><a href="/posts/">All posts →</a></p>
  </section>
</Base>
