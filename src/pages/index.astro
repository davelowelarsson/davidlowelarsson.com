---
import { getCollection } from 'astro:content';
import { SHOW_DRAFTS } from 'astro:env/server';
import PostList from '../components/PostList.astro';
import Base from '../layouts/Base.astro';
import { isVisible, sortByPubDateDesc } from '../lib/posts';
import { profilePageJsonLd } from '../lib/seo';

const recent = sortByPubDateDesc(
  await getCollection('posts', ({ data }) => isVisible(data, SHOW_DRAFTS)),
).slice(0, 3);

const site = Astro.site?.href ?? 'https://davidlowelarsson.com';
---

<Base title="David Lowe Larsson" jsonLd={profilePageJsonLd(site)}>
  <h1>David Lowe Larsson</h1>
  <p>
    I lead engineering teams and care about how software gets made — flow, feedback, and the DORA
    metrics that make improvement visible. My roots are in 3D digital art, which still shapes how I
    think about building things: craft first, then scale.
  </p>
  <p>
    I write <a href="/posts/">notes and essays</a> here — thoughts on technical leadership,
    today-I-learned snippets, and the occasional experiment.
  </p>

  <section aria-labelledby="recent-heading">
    <h2 id="recent-heading" class="section-heading">Recent</h2>
    <PostList posts={recent} />
    <p class="all-posts"><a href="/posts/">All posts →</a></p>
  </section>
</Base>
