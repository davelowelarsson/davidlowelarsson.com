---
import { CLOUDFLARE_ANALYTICS_TOKEN } from 'astro:env/client';
import Lightbox from '../components/Lightbox.astro';
import Mermaid from '../components/Mermaid.astro';
import { AUTHOR } from '../lib/seo';

interface Props {
  title: string;
  description?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  publishedTime?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description = 'Notes from David Lowe Larsson — platform engineering, flow, home-lab experiments, and roots in 3D art.',
  ogType = 'website',
  ogImage,
  publishedTime,
  jsonLd,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = ogImage ?? new URL('/og-default.png', Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="David Lowe Larsson" href="/rss.xml" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content={AUTHOR.name} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    {
      CLOUDFLARE_ANALYTICS_TOKEN && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={JSON.stringify({ token: CLOUDFLARE_ANALYTICS_TOKEN })}
        />
      )
    }
  </head>
  <body>
    <header>
      <nav>
        <a href="/">David Lowe Larsson</a>
        <a href="/posts/">Posts</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <a href={AUTHOR.linkedin}>LinkedIn</a>
      <a href={AUTHOR.github}>GitHub</a>
      <a href="/rss.xml">RSS</a>
    </footer>
    <Lightbox />
    <Mermaid />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light dark;

    --font-prose: system-ui, -apple-system, 'Segoe UI', sans-serif;
    --font-mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;

    --ink: light-dark(#1b1b1f, #e6e6e9);
    --muted: light-dark(#6f6f78, #9c9ca6);
    --hairline: light-dark(rgb(0 0 0 / 12%), rgb(255 255 255 / 16%));
    --chip: light-dark(rgb(0 0 0 / 5%), rgb(255 255 255 / 9%));
    --bg: light-dark(#ffffff, #111113);
    --warn: light-dark(#a16207, #fbbf24);
    --focus: light-dark(#2563eb, #93b4ff);
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0 auto;
    padding: 2rem 1.25rem 4rem;
    max-width: 42rem;
    font-family: var(--font-prose);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--ink);
    background: var(--bg);
    text-rendering: optimizeLegibility;
  }

  :focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* ── Prose ── */

  h1 {
    font-size: 1.625rem;
    font-weight: 650;
    letter-spacing: -0.015em;
    line-height: 1.25;
    margin: 0 0 0.5rem;
  }

  h2 {
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 2.25em 0 0.5em;
  }

  h3 {
    font-size: 1.0625rem;
    font-weight: 600;
    margin: 1.75em 0 0.5em;
  }

  p {
    margin: 0 0 1.25em;
  }

  a {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: var(--muted);
    text-underline-offset: 0.15em;
  }

  a:hover {
    text-decoration-color: currentColor;
  }

  blockquote {
    margin: 1.5rem 0;
    padding: 0.25rem 0 0.25rem 1.25rem;
    border-left: 2px solid var(--hairline);
    color: var(--muted);
  }

  hr {
    border: 0;
    border-top: 1px solid var(--hairline);
    margin: 2.5rem 0;
  }

  main img {
    max-width: 100%;
    height: auto;
  }

  /* Excalidraw exports dark strokes on a transparent background — legible on
     a white page, invisible on a dark one. Invert lightness and spin the hue
     back so black-on-transparent reads as light-on-transparent in dark mode,
     without touching the exported SVG file itself. */
  @media (prefers-color-scheme: dark) {
    img[src*='excalidraw'] {
      filter: invert(0.92) hue-rotate(180deg);
    }
  }

  /* In-article images and diagrams: centered, with room to breathe.
     cursor: zoom-in signals the Lightbox component's click-to-enlarge
     affordance (progressive enhancement — harmless with JS disabled). */
  article > img,
  article p > img {
    display: block;
    margin: 2rem auto;
    cursor: zoom-in;
  }

  /* ── Header / footer ── */

  header nav {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  header nav a {
    text-decoration: none;
    color: var(--muted);
  }

  header nav a:first-child {
    font-weight: 600;
    color: var(--ink);
  }

  header nav a:hover {
    color: var(--ink);
  }

  footer {
    display: flex;
    gap: 1.5rem;
    margin-top: 5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--hairline);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
  }

  footer a {
    color: var(--muted);
    text-decoration: none;
  }

  footer a:hover {
    color: var(--ink);
  }

  /* ── The meta rail (signature element) ── */

  .post-meta {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.02em;
    color: var(--muted);
  }

  .badge {
    letter-spacing: 0.05em;
  }

  a.badge {
    text-decoration: none;
  }

  a.badge:hover {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .filter-rail {
    display: flex;
    gap: 1rem;
    margin: 0.75rem 0 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    letter-spacing: 0.03em;
  }

  .filter-rail a {
    color: var(--muted);
    text-decoration: none;
  }

  .filter-rail a:hover {
    color: var(--ink);
  }

  .filter-rail [aria-current] {
    color: var(--ink);
  }

  .category-description {
    color: var(--muted);
    margin-top: -0.25rem;
  }

  /* Quiet category tints — legible as monochrome, scannable as color */
  .badge-essay {
    color: light-dark(#4338ca, #a5b4fc);
  }

  .badge-til {
    color: light-dark(#047857, #6ee7b7);
  }

  .badge-experiment {
    color: light-dark(#0e7490, #67e8f9);
  }

  .badge-warning {
    color: var(--warn);
  }

  /* Error-page illustrations keep their own gray plate — framed like a card
     so the fixed background reads as intentional in both themes. */
  .error-illustration {
    display: block;
    margin: 2.5rem auto;
    border-radius: 12px;
    border: 1px solid var(--hairline);
    max-width: 100%;
    height: auto;
  }

  .section-heading {
    margin-top: 3.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--hairline);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .all-posts {
    margin-top: 1rem;
  }

  .all-posts a {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--muted);
    text-decoration: none;
  }

  .all-posts a:hover {
    color: var(--ink);
  }

  /* ── Post list ── */

  .post-list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
  }

  .post-list li + li {
    margin-top: 0.25rem;
  }

  .post-link {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 0.875rem 0.75rem;
    margin: 0 -0.75rem;
    border-radius: 10px;
    text-decoration: none;
  }

  .post-link:hover {
    background: var(--chip);
  }

  .post-cover {
    flex: 0 0 auto;
    width: 5.5rem;
    height: auto;
    border-radius: 6px;
    border: 1px solid var(--hairline);
  }

  .post-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }

  .post-title {
    font-weight: 550;
    line-height: 1.4;
  }

  .post-description {
    font-size: 0.9375rem;
    color: var(--muted);
    line-height: 1.5;
  }

  .post-list .post-meta {
    margin-top: 0.15rem;
  }

  /* ── Code ── */

  code {
    font-family: var(--font-mono);
  }

  :not(pre) > code {
    font-size: 0.875em;
    padding: 0.1em 0.35em;
    border-radius: 4px;
    background: var(--chip);
  }

  pre {
    margin: 1.5rem 0;
    padding: 1rem 1.25rem;
    border-radius: 8px;
    border: 1px solid var(--hairline);
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.55;
  }

  /* ── Tables ── */

  table {
    border-collapse: collapse;
    width: 100%;
    margin: 1.5rem 0;
    font-size: 0.9375rem;
  }

  th {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--muted);
    font-weight: 500;
  }

  th,
  td {
    text-align: left;
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--hairline);
  }

  @media (prefers-reduced-motion: no-preference) {
    .post-link {
      transition: background 120ms ease;
    }
  }
</style>
