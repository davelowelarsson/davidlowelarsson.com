---
import { CLOUDFLARE_ANALYTICS_TOKEN } from 'astro:env/client';
import Lightbox from '../components/Lightbox.astro';
import Mermaid from '../components/Mermaid.astro';
import { SALTAST_URL } from '../lib/saltast';
import { AUTHOR } from '../lib/seo';

interface Props {
  title: string;
  description?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  publishedTime?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description = 'Notes from David Lowe Larsson — platform engineering, flow, home-lab experiments, and roots in 3D art.',
  ogType = 'website',
  ogImage,
  publishedTime,
  jsonLd,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = ogImage ?? new URL('/og-default.png', Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="David Lowe Larsson" href="/rss.xml" />
    {/* Warm the connection to saltast.com so the footer tally fetch is quicker. */}
    <link rel="preconnect" href="https://saltast.com" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content={AUTHOR.name} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    {
      CLOUDFLARE_ANALYTICS_TOKEN && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={JSON.stringify({ token: CLOUDFLARE_ANALYTICS_TOKEN })}
        />
      )
    }
  </head>
  <body>
    <header>
      <nav>
        <a href="/">David Lowe Larsson</a>
        <a href="/posts/">Posts</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <a href={AUTHOR.linkedin}>LinkedIn</a>
      <a href={AUTHOR.github}>GitHub</a>
      <a href="/rss.xml">RSS</a>
      {/*
        saltast.com link renders immediately; the tally span sits AFTER it and
        is the last content on the page, so the script filling it grows only
        downward — the link never moves, nothing above shifts (no CLS). No JS →
        just the link. See the saltast script below + docs/astro-field-guide.md.
      */}
      <span class="saltast-footer"
        ><a href={SALTAST_URL}>saltast.com</a><span
          class="saltast-tally"
          data-saltast-tally
          aria-live="polite"></span></span>
    </footer>
    <Lightbox />
    <Mermaid />
    <script>
      import {
        type ExperimentSummary,
        SALTAST_SUMMARY_URL,
        experimentStats,
        parseSummary,
        totalLabel,
      } from '../lib/saltast';

      const elements = document.querySelectorAll('[data-saltast-tally]');
      if (elements.length > 0) {
        const CACHE_KEY = 'saltast:summary';

        const readCache = () => {
          try {
            const raw = sessionStorage.getItem(CACHE_KEY);
            return raw ? parseSummary(JSON.parse(raw)) : null;
          } catch {
            return null;
          }
        };

        const render = (el: Element, summary: ExperimentSummary) => {
          el.textContent = '';
          el.setAttribute('data-saltast-state', 'loaded');

          const total = document.createElement('span');
          total.className = 'saltast-total';
          total.textContent = totalLabel(summary);
          el.append(total);

          const stats = document.createElement('span');
          stats.className = 'saltast-stats';
          for (const { key, count } of experimentStats(summary)) {
            const stat = document.createElement('span');
            stat.className = `saltast-stat saltast-stat--${key}`;
            const dot = document.createElement('span');
            dot.className = 'saltast-dot';
            dot.setAttribute('aria-hidden', 'true');
            stat.append(dot, document.createTextNode(`${count} ${key}`));
            stats.append(stat);
          }
          el.append(stats);
        };

        const offline = (el: Element) => {
          el.textContent = 'offline';
          el.setAttribute('data-saltast-state', 'offline');
        };

        // Stale-while-revalidate: paint the cached tally instantly on repeat views
        // (no waiting on the network), then refresh in the background. Briefly
        // stale is fine — saltast.com is the real dashboard one click away.
        const cached = readCache();
        if (cached) for (const el of elements) render(el, cached);

        (async () => {
          let fresh = null;
          try {
            const response = await fetch(SALTAST_SUMMARY_URL, {
              headers: { accept: 'application/json' },
            });
            if (response.ok) fresh = parseSummary(await response.json());
          } catch {
            // offline / CORS-blocked — keep any cached render.
          }
          if (fresh) {
            try {
              sessionStorage.setItem(CACHE_KEY, JSON.stringify(fresh));
            } catch {
              /* storage unavailable — non-fatal */
            }
            for (const el of elements) render(el, fresh);
          } else if (!cached) {
            for (const el of elements) offline(el);
          }
        })();
      }
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light dark;

    --font-prose: system-ui, -apple-system, 'Segoe UI', sans-serif;
    --font-mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;

    --ink: light-dark(#1b1b1f, #e6e6e9);
    --muted: light-dark(#6f6f78, #9c9ca6);
    --hairline: light-dark(rgb(0 0 0 / 12%), rgb(255 255 255 / 16%));
    --chip: light-dark(rgb(0 0 0 / 5%), rgb(255 255 255 / 9%));
    --bg: light-dark(#ffffff, #111113);
    --warn: light-dark(#a16207, #fbbf24);
    --focus: light-dark(#2563eb, #93b4ff);
    --status-up: light-dark(#15803d, #4ade80);
    --status-down: light-dark(#b91c1c, #f87171);
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0 auto;
    padding: 2rem 1.25rem 4rem;
    max-width: 42rem;
    font-family: var(--font-prose);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--ink);
    background: var(--bg);
    text-rendering: optimizeLegibility;
  }

  :focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* ── Prose ── */

  h1 {
    font-size: 1.625rem;
    font-weight: 650;
    letter-spacing: -0.015em;
    line-height: 1.25;
    margin: 0 0 0.5rem;
  }

  h2 {
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 2.25em 0 0.5em;
  }

  h3 {
    font-size: 1.0625rem;
    font-weight: 600;
    margin: 1.75em 0 0.5em;
  }

  p {
    margin: 0 0 1.25em;
  }

  a {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: var(--muted);
    text-underline-offset: 0.15em;
  }

  a:hover {
    text-decoration-color: currentColor;
  }

  blockquote {
    margin: 1.5rem 0;
    padding: 0.25rem 0 0.25rem 1.25rem;
    border-left: 2px solid var(--hairline);
    color: var(--muted);
  }

  hr {
    border: 0;
    border-top: 1px solid var(--hairline);
    margin: 2.5rem 0;
  }

  main img {
    max-width: 100%;
    height: auto;
  }

  /* Excalidraw exports dark strokes on a transparent background — legible on
     a white page, invisible on a dark one. Invert lightness and spin the hue
     back so black-on-transparent reads as light-on-transparent in dark mode,
     without touching the exported SVG file itself. */
  @media (prefers-color-scheme: dark) {
    img[src*='excalidraw'] {
      filter: invert(0.92) hue-rotate(180deg);
    }
  }

  /* In-article images and diagrams: centered, with room to breathe.
     cursor: zoom-in signals the Lightbox component's click-to-enlarge
     affordance (progressive enhancement — harmless with JS disabled). */
  article > img,
  article p > img {
    display: block;
    margin: 2rem auto;
    cursor: zoom-in;
  }

  /* ── Header / footer ── */

  header nav {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  header nav a {
    text-decoration: none;
    color: var(--muted);
  }

  header nav a:first-child {
    font-weight: 600;
    color: var(--ink);
  }

  header nav a:hover {
    color: var(--ink);
  }

  footer {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    margin-top: 5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--hairline);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
  }

  footer a {
    color: var(--muted);
    text-decoration: none;
  }

  footer a:hover {
    color: var(--ink);
  }

  /* saltast link pushed to the far right; its live tally stacks underneath it,
     right-aligned. The tally is below the link and the footer is the last
     content on the page, so filling it never moves the link or anything above. */
  .saltast-footer {
    margin-left: auto;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    text-align: right;
    gap: 0.15rem;
  }

  .saltast-tally {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    align-items: baseline;
    gap: 0.15rem 0.6rem;
    color: var(--muted);
  }

  /* Colored status breakdown — shared by the footer tally and the experiments
     callout (JS-created nodes, so these live in the global sheet, not scoped). */
  .saltast-stats {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.15rem 0.7rem;
  }

  .saltast-stat {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--stat-color, var(--muted));
  }

  .saltast-stat--up {
    --stat-color: var(--status-up);
  }
  .saltast-stat--down {
    --stat-color: var(--status-down);
  }
  .saltast-stat--unknown {
    --stat-color: var(--warn);
  }

  .saltast-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: currentColor;
  }

  .saltast-total {
    color: var(--muted);
  }

  /* ── The meta rail (signature element) ── */

  /* Year dividers in archive listings — the quiet signal that a 2013 study
     is a 2013 study. Same mono voice as the meta rail. */
  .year-heading {
    margin: 2.5rem 0 0.25rem;
    padding-top: 1rem;
    border-top: 1px solid var(--hairline);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--muted);
  }

  .tagline {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    letter-spacing: 0.03em;
    color: var(--muted);
    margin: -0.25rem 0 2rem;
  }

  .post-meta {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.02em;
    color: var(--muted);
  }

  .badge {
    letter-spacing: 0.05em;
  }

  a.badge {
    text-decoration: none;
  }

  a.badge:hover {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .filter-rail {
    display: flex;
    gap: 1rem;
    margin: 0.75rem 0 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    letter-spacing: 0.03em;
  }

  .filter-rail a {
    color: var(--muted);
    text-decoration: none;
  }

  .filter-rail a:hover {
    color: var(--ink);
  }

  .filter-rail [aria-current] {
    color: var(--ink);
  }

  .category-description {
    color: var(--muted);
    margin-top: -0.25rem;
  }

  /* Quiet category tints — legible as monochrome, scannable as color */
  .badge-essay {
    color: light-dark(#4338ca, #a5b4fc);
  }

  .badge-til {
    color: light-dark(#047857, #6ee7b7);
  }

  .badge-experiment {
    color: light-dark(#0e7490, #67e8f9);
  }

  .badge-warning {
    color: var(--warn);
  }

  /* Preview-only: a non-draft post queued for a future liveFrom. Calm blue so
     it reads as "coming", distinct from the amber "draft". */
  .badge-scheduled {
    color: var(--focus);
  }

  /* Error-page illustrations keep their own gray plate — framed like a card
     so the fixed background reads as intentional in both themes. */
  .error-illustration {
    display: block;
    margin: 2.5rem auto;
    border-radius: 12px;
    border: 1px solid var(--hairline);
    max-width: 100%;
    height: auto;
  }

  .section-heading {
    margin-top: 3.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--hairline);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .all-posts {
    margin-top: 1rem;
  }

  .all-posts a {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--muted);
    text-decoration: none;
  }

  .all-posts a:hover {
    color: var(--ink);
  }

  /* ── Post list ── */

  .post-list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
  }

  .post-list li + li {
    margin-top: 0.25rem;
  }

  .post-link {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 0.875rem 0.75rem;
    margin: 0 -0.75rem;
    border-radius: 10px;
    text-decoration: none;
  }

  .post-link:hover {
    background: var(--chip);
  }

  .post-cover {
    flex: 0 0 auto;
    width: 5.5rem;
    height: auto;
    border-radius: 6px;
    border: 1px solid var(--hairline);
  }

  .post-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }

  .post-title {
    font-weight: 550;
    line-height: 1.4;
  }

  .post-description {
    font-size: 0.9375rem;
    color: var(--muted);
    line-height: 1.5;
  }

  .post-list .post-meta {
    margin-top: 0.15rem;
  }

  /* ── Code ── */

  code {
    font-family: var(--font-mono);
  }

  :not(pre) > code {
    font-size: 0.875em;
    padding: 0.1em 0.35em;
    border-radius: 4px;
    background: var(--chip);
  }

  pre {
    margin: 1.5rem 0;
    padding: 1rem 1.25rem;
    border-radius: 8px;
    border: 1px solid var(--hairline);
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.55;
  }

  /* ── Tables ── */

  table {
    border-collapse: collapse;
    width: 100%;
    margin: 1.5rem 0;
    font-size: 0.9375rem;
  }

  th {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--muted);
    font-weight: 500;
  }

  th,
  td {
    text-align: left;
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--hairline);
  }

  @media (prefers-reduced-motion: no-preference) {
    .post-link {
      transition: background 120ms ease;
    }
  }
</style>
