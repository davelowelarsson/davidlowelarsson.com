---
import type { ProcessRailStep } from '../lib/process-rail';

interface Props {
  step: ProcessRailStep;
}

const { step } = Astro.props;

const SYSTEM_META = {
  job: { label: 'Job', tone: 'job' },
  slack: { label: 'Slack', tone: 'slack' },
  spotify: { label: 'Spotify', tone: 'spotify' },
  diff: { label: 'Diff', tone: 'diff' },
} as const;

const system = SYSTEM_META[step.system];
const sample = step.sample;

function formatList(items: string[]) {
  return `[
${items.map((item) => `  '${item}'`).join(',\n')}
]`;
}
---

<figure class={`process-step-card process-step-card--${system.tone}`} data-process-step-card-id={step.id}>
  <figcaption class="process-step-card__header">
    <span class={`process-step-card__system process-step-card__system--${system.tone}`} aria-hidden="true">
      {step.system === 'spotify' && (
        <svg data-brand-mark="spotify" viewBox="0 0 64 64" focusable="false">
          <circle cx="32" cy="32" r="31" />
          <path d="M18 24.3c10.6-3.1 20.7-2.1 30.2 3" />
          <path d="M20.2 32.4c8.2-2.4 16.6-1.6 23.4 2.5" />
          <path d="M22 39.7c5.8-1.7 12.4-1.2 17.6 1.9" />
        </svg>
      )}
      {step.system === 'slack' && (
        <svg data-brand-mark="slack" viewBox="0 0 64 64" focusable="false">
          <rect x="7" y="25" width="25" height="12" rx="6" class="slack-cyan" />
          <rect x="26" y="7" width="12" height="25" rx="6" class="slack-cyan" />
          <rect x="32" y="7" width="12" height="25" rx="6" class="slack-green" />
          <rect x="44" y="25" width="13" height="12" rx="6" class="slack-green" />
          <rect x="32" y="32" width="25" height="12" rx="6" class="slack-yellow" />
          <rect x="26" y="32" width="12" height="25" rx="6" class="slack-yellow" />
          <rect x="20" y="32" width="12" height="25" rx="6" class="slack-red" />
          <rect x="7" y="27" width="13" height="12" rx="6" class="slack-red" />
        </svg>
      )}
      {step.system === 'diff' && (
        <svg viewBox="0 0 24 24" focusable="false">
          <path d="M5 12h14" />
          <path d="M12 5v14" />
        </svg>
      )}
      {step.system === 'job' && (
        <svg viewBox="0 0 24 24" focusable="false">
          <path d="M12 3v3" />
          <path d="M12 18v3" />
          <path d="M3 12h3" />
          <path d="M18 12h3" />
          <circle cx="12" cy="12" r="4" />
        </svg>
      )}
    </span>
    <span class="process-step-card__header-copy">
      <span class="process-step-card__system-label">{system.label}</span>
      <strong>{step.label}</strong>
      {step.hint && <span>{step.hint}</span>}
    </span>
  </figcaption>

  {sample && (
    <div class="process-step-card__sample">
      {sample.operation && <code class="process-step-card__operation">{sample.operation}</code>}

      {step.system === 'slack' && sample.left && (
        <div class="process-step-card__surface process-step-card__surface--slack" aria-label="Anonymized Slack message preview">
          {sample.left.map((item, index) => (
            <div class="process-step-card__message">
              <span class="process-step-card__avatar" aria-hidden="true"></span>
              <span class="process-step-card__message-body">
                <span class="process-step-card__message-meta">person {index + 1} · friday theme</span>
                <span class="process-step-card__link-pill">{item}</span>
              </span>
            </div>
          ))}
        </div>
      )}

      {step.system === 'spotify' && sample.result && (
        <div class="process-step-card__surface process-step-card__surface--spotify" aria-label="Anonymized Spotify playlist preview">
          {sample.result.map((item, index) => (
            <div class="process-step-card__playlist-row">
              <span class="process-step-card__row-index">{index + 1}</span>
              <span class="process-step-card__album" aria-hidden="true"></span>
              <span class="process-step-card__track">
                <span>{item}</span>
                <span>auto-added from Slack</span>
              </span>
              <span class="process-step-card__duration">{index === 0 ? '3:19' : '3:30'}</span>
            </div>
          ))}
        </div>
      )}

      <div class="process-step-card__grid">
        {sample.left && step.system !== 'slack' && (
          <section class="process-step-card__block">
            <p>{sample.leftLabel ?? 'Input'}</p>
            <pre><code>{formatList(sample.left)}</code></pre>
          </section>
        )}

        {sample.right && (
          <section class="process-step-card__block">
            <p>{sample.rightLabel ?? 'Current state'}</p>
            <pre><code>{formatList(sample.right)}</code></pre>
          </section>
        )}

        {sample.result && step.system !== 'spotify' && (
          <section class="process-step-card__block process-step-card__block--result">
            <p>{sample.resultLabel ?? 'Result'}</p>
            <pre><code>{formatList(sample.result)}</code></pre>
          </section>
        )}
      </div>
    </div>
  )}
</figure>

<style>
  .process-step-card {
    --card-accent: var(--focus);
    --card-accent-bg: var(--chip);

    margin: 1.1rem 0 1.75rem;
    border: 1px solid var(--hairline);
    border-left: 3px solid var(--card-accent);
    border-radius: 0.5rem;
    background: light-dark(#fbfbfd, #19191d);
    padding: 0.8rem;
    box-shadow: 0 0.75rem 1.8rem rgb(0 0 0 / 10%);
  }

  .process-step-card--slack {
    --card-accent: light-dark(#7c3aed, #c084fc);
    --card-accent-bg: light-dark(#f4e8ff, #321943);
  }

  .process-step-card--spotify {
    --card-accent: light-dark(#15803d, #4ade80);
    --card-accent-bg: light-dark(#ddfbe7, #123322);
  }

  .process-step-card--diff {
    --card-accent: light-dark(#c2410c, #fb923c);
    --card-accent-bg: light-dark(#ffedd5, #3e2412);
  }

  .process-step-card__header {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.65rem;
    align-items: start;
  }

  .process-step-card__system {
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--card-accent-bg);
    color: var(--card-accent);
  }

  .process-step-card__system svg {
    width: 1.28rem;
    height: 1.28rem;
  }

  .process-step-card__system svg:not([data-brand-mark]) {
    stroke: currentColor;
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  [data-brand-mark='spotify'] circle {
    fill: #1ed760;
  }

  [data-brand-mark='spotify'] path {
    fill: none;
    stroke: #121212;
    stroke-width: 5.4;
    stroke-linecap: round;
  }

  [data-brand-mark='slack'] .slack-cyan {
    fill: #36c5f0;
  }

  [data-brand-mark='slack'] .slack-green {
    fill: #2eb67d;
  }

  [data-brand-mark='slack'] .slack-yellow {
    fill: #ecb22e;
  }

  [data-brand-mark='slack'] .slack-red {
    fill: #e01e5a;
  }

  .process-step-card__header-copy {
    display: grid;
    gap: 0.08rem;
    min-width: 0;
  }

  .process-step-card__system-label {
    color: var(--muted);
    font-size: 0.68rem;
    line-height: 1.2;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .process-step-card__header-copy strong {
    font-size: 0.98rem;
    line-height: 1.35;
  }

  .process-step-card__header-copy span:last-child:not(.process-step-card__system-label) {
    color: var(--muted);
    font-size: 0.84rem;
    line-height: 1.45;
  }

  .process-step-card__sample {
    margin-top: 0.8rem;
    border-top: 1px solid var(--hairline);
    padding-top: 0.75rem;
  }

  .process-step-card__surface {
    margin-bottom: 0.7rem;
    border: 1px solid var(--hairline);
    border-radius: 0.55rem;
    background: light-dark(#ffffff, #101114);
    padding: 0.65rem;
  }

  .process-step-card__surface--slack {
    display: grid;
    gap: 0.6rem;
  }

  .process-step-card__message {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.55rem;
    align-items: start;
  }

  .process-step-card__avatar {
    width: 1.65rem;
    height: 1.65rem;
    border-radius: 0.35rem;
    background:
      linear-gradient(135deg, rgb(255 255 255 / 36%), transparent 42%),
      var(--card-accent-bg);
  }

  .process-step-card__message-body {
    display: grid;
    gap: 0.25rem;
    min-width: 0;
  }

  .process-step-card__message-meta {
    color: var(--muted);
    font-size: 0.72rem;
    line-height: 1.2;
  }

  .process-step-card__link-pill {
    display: block;
    width: fit-content;
    max-width: 100%;
    border-radius: 0.25rem;
    background: light-dark(#e8f7ff, #103040);
    color: light-dark(#0369a1, #67e8f9);
    padding: 0.12rem 0.28rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    line-height: 1.4;
    overflow-wrap: anywhere;
  }

  .process-step-card__surface--spotify {
    display: grid;
    gap: 0.42rem;
  }

  .process-step-card__playlist-row {
    display: grid;
    grid-template-columns: 1.5rem auto minmax(0, 1fr) auto;
    gap: 0.55rem;
    align-items: center;
    min-width: 0;
  }

  .process-step-card__row-index,
  .process-step-card__duration {
    color: var(--muted);
    font-size: 0.72rem;
  }

  .process-step-card__album {
    width: 1.85rem;
    height: 1.85rem;
    border-radius: 0.25rem;
    background:
      linear-gradient(135deg, rgb(255 255 255 / 32%), transparent 45%),
      var(--card-accent-bg);
  }

  .process-step-card__track {
    display: grid;
    gap: 0.05rem;
    min-width: 0;
  }

  .process-step-card__track span:first-child {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 0.82rem;
    line-height: 1.25;
  }

  .process-step-card__track span:last-child {
    color: var(--muted);
    font-size: 0.72rem;
    line-height: 1.2;
  }

  .process-step-card__operation {
    display: block;
    margin-bottom: 0.65rem;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.74rem;
    line-height: 1.4;
    white-space: normal;
  }

  .process-step-card__grid {
    display: grid;
    gap: 0.55rem;
  }

  .process-step-card__block {
    min-width: 0;
  }

  .process-step-card__block p {
    margin: 0 0 0.25rem;
    color: var(--muted);
    font-size: 0.72rem;
    line-height: 1.3;
  }

  .process-step-card__block pre {
    margin: 0;
    border: 1px solid var(--hairline);
    border-radius: 0.4rem;
    background: light-dark(#f3f5f9, #111216);
    padding: 0.55rem;
    overflow-x: auto;
    font-size: 0.72rem;
    line-height: 1.5;
  }

  .process-step-card__block code {
    font-family: var(--font-mono);
  }

  .process-step-card__block--result pre {
    border-color: var(--card-accent);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--card-accent) 20%, transparent);
  }

  @media (min-width: 38rem) {
    .process-step-card__grid {
      grid-template-columns: repeat(auto-fit, minmax(9rem, 1fr));
    }
  }
</style>