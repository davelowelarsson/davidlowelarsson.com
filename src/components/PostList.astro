---
import { type Category, formatScheduleDate, isScheduled } from '../lib/posts';

interface CoverImage {
  src: string;
  width: number;
  height: number;
}

interface Props {
  posts: Array<{
    id: string;
    data: {
      title: string;
      description?: string;
      pubDate: Date;
      category: Category;
      draft: boolean;
      liveFrom?: string;
      cover?: CoverImage;
      coverAlt?: string;
    };
  }>;
}

const { posts } = Astro.props;

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' });
---

<ul class="post-list">
  {
    posts.map((post) => (
      <li>
        <a class="post-link" href={`/posts/${post.id}/`}>
          {post.data.cover && (
            <img
              class="post-cover"
              src={post.data.cover.src}
              alt={post.data.coverAlt ?? ''}
              width={post.data.cover.width}
              height={post.data.cover.height}
              loading="lazy"
              decoding="async"
            />
          )}
          <span class="post-text">
            <span class="post-title">{post.data.title}</span>
            {post.data.description && <span class="post-description">{post.data.description}</span>}
            <span class="post-meta">
              <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
              <span class={`badge badge-${post.data.category}`}>{post.data.category}</span>
              {post.data.draft && <span class="badge badge-warning">draft</span>}
              {isScheduled(post.data) && post.data.liveFrom && (
                <span class="badge badge-scheduled">scheduled · {formatScheduleDate(post.data.liveFrom)}</span>
              )}
            </span>
          </span>
        </a>
      </li>
    ))
  }
</ul>
